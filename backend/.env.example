# Copy to backend/.env and fill in real values. Do not put credentials in docker-compose.yml.
#
# Database — local Docker Postgres (default)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/approval_workflow

# Database — Neon example
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/approval_workflow?sslmode=require

# Database — Supabase example
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require

SECRET_KEY=dev-secret-change-in-production

# Comma-separated origins allowed to call the API (required for production)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Attachments: Google Drive (production / Render) ──
STORAGE_BACKEND=google_drive
GOOGLE_DRIVE_FOLDER_ID=your_folder_id
# Paste the full service account JSON on one line (Render env var or here):
GOOGLE_DRIVE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# Alternative for local dev: mount ./secrets and use a file path
# GOOGLE_DRIVE_CREDENTIALS_FILE=./secrets/google-service-account.json

# ── Attachments: local disk (development only) ──
# STORAGE_BACKEND=local
# UPLOAD_DIR=uploads
